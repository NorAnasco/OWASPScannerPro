# ══════════════════════════════════════════════════════════════
#  OWASP Scanner Pro — Variables d'environnement
#  Copiez ce fichier en .env et remplissez vos vraies valeurs.
#  NE JAMAIS committer .env dans Git !
# ══════════════════════════════════════════════════════════════

# ── Clé Anthropic (obligatoire pour l'analyse IA) ─────────────
ANTHROPIC_API_KEY=sk-ant-votre-vraie-clé
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Flask ─────────────────────────────────────────────────────
SECRET_KEY=changez-cette-valeur-en-production
DEBUG=true

# ── OWASP ZAP ─────────────────────────────────────────────────
# Mettez à true si ZAP est installé et démarré en daemon
ZAP_USE_REAL=false
ZAP_HOST=127.0.0.1
ZAP_PORT=8080
ZAP_API_KEY=changeme

# ── Nikto ─────────────────────────────────────────────────────
NIKTO_USE_REAL=false
NIKTO_TIMEOUT=120

# ── Burp Suite Pro ────────────────────────────────────────────
BURP_USE_REAL=false
BURP_HOST=127.0.0.1
BURP_PORT=1337
BURP_API_KEY=

# ── Nmap (optionnel) ──────────────────────────────────────────
# Mettez à true si Nmap est installé
NMAP_USE_REAL=true

